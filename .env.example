# ── AI (packages/ai spike·bench 실행용) ──
OPENAI_API_KEY=

# ── Supabase ──
# 로컬 개발: `supabase start` 후 아래 값 사용 (anon key는 CLI 출력 참조 — 로컬 데모 키)
# EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
# EXPO_PUBLIC_SUPABASE_ANON_KEY=<supabase start 출력의 anon key>
# 미설정 시 앱은 Dev Mock Auth 모드로 부팅된다.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
